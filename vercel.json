<script>
// ─── DEMO CONTENT ───
const DEMO_CONTENT = `I've been working remotely for 3 years now, and I finally figured out the productivity system that works for me. The key insight: stop trying to be productive all day. Instead, design your day around 3 deep work blocks of 90 minutes each. Everything else — meetings, emails, admin — gets squeezed into the gaps. My output doubled in 6 months. Here's exactly how I set it up...`;

const DEMO_OUTPUTS = {
  twitter: `🧵 I doubled my output in 6 months with one rule:\n\nStop trying to be productive ALL day.\n\nHere's the 90-minute deep work system that changed everything 👇\n\n1/ Most people spread their focus thin across the whole day.\n\nEmails in the morning. Meetings at noon. "Productive" work squeezed in between.\n\nThat's why you're exhausted but feel like you got nothing done.\n\n2/ The fix: Design your day around 3 deep work blocks.\n\nEach block = 90 minutes of uninterrupted, focused work.\n\nNo notifications. No Slack. No exceptions.\n\n3/ Results after 6 months:\n→ More output than ever\n→ Done by 3pm most days\n→ Actual energy left at end of day\n\nTry it for one week. You won't go back.`,
  linkedin: `I spent 2 years working "hard" and getting mediocre results.\n\nThen I made one change — and my output doubled in 6 months.\n\nThe insight: stop trying to be productive all day.\n\nMost of us design our days reactively. Emails first thing. Back-to-back meetings. Actual work crammed in wherever it fits.\n\nThe result? Busy all day, nothing to show for it.\n\nHere's what I do instead:\n\nI design my day around 3 deep work blocks — 90 minutes each, protected fiercely. No notifications. No meetings. No interruptions.\n\nEverything else gets scheduled around those blocks.\n\nAfter 6 months: my output genuinely doubled. I finish earlier than ever.\n\nThe counterintuitive truth: less time "being productive" → more actual production.\n\nWhat's your deep work setup? 👇`,
  instagram: `The productivity hack that actually worked 🙌\n\nAfter 3 years of remote work, I finally cracked the code.\n\n✨ 3 deep work blocks × 90 min = more output than 8 hours of "busy"\n\nThe secret isn't working more hours.\nIt's protecting the hours that matter.\n\nDrop a 🔥 if you needed to hear this today.\n\n#productivity #remotework #deepwork #worksmarter #focusmode #entrepreneurmindset`,
  tiktok: `Wait — you don't need more hours. You need THIS instead 👇\n\nI worked 10-hour days for years and still felt behind.\n\nThen I switched to 3 deep work blocks — 90 minutes each — and my output literally doubled.\n\nHere's the system in 60 seconds...`,
  newsletter: `Hey [First Name],\n\nQuick question: when did you last finish your day feeling like you actually got everything done?\n\nIf you're like most remote workers, that feeling is rare.\n\nThis week I'm sharing the one shift that changed everything for me — and how you can test it starting tomorrow morning.\n\nIt takes 5 minutes to set up. If it works half as well for you as it did for me, it might be the most valuable 5 minutes of your week.\n\nLet's dive in 👇`
};

// ─── MODE ───
let appMode = 'demo';
function setMode(m) {
  appMode = m;
  document.getElementById('demoBtn').classList.toggle('on', m==='demo');
  document.getElementById('liveBtn').classList.toggle('on', m==='live');
  const apiSec = document.getElementById('apiSection');
  apiSec.style.display = m==='live' ? 'flex' : 'none';
  document.querySelectorAll('.demo-tag').forEach(t => t.style.display = m==='demo' ? 'inline-block' : 'none');
}

// ─── GENERATE ───
async function generate() {
  const content = document.getElementById('contentInput').value.trim() || DEMO_CONTENT;
  document.getElementById('contentInput').value = content;

  const btn = document.getElementById('genBtn');
  const txt = document.getElementById('btnTxt');
  const spin = document.getElementById('spinner');
  btn.disabled = true; txt.style.display='none'; spin.style.display='block';

  const platforms = ['twitter','linkedin','instagram','tiktok','newsletter'];
  platforms.forEach(p => {
    document.getElementById(`out-${p}`).textContent = 'Generating…';
    document.getElementById(`card-${p}`).classList.add('loading');
  });

  if (appMode === 'demo') {
    const delays = [600,1100,1600,2000,2400];
    await Promise.all(platforms.map((p,i) => new Promise(r => setTimeout(() => {
      document.getElementById(`out-${p}`).textContent = DEMO_OUTPUTS[p];
      document.getElementById(`card-${p}`).classList.remove('loading');
      r();
    }, delays[i]))));
    showNotif('✅ Done! (Demo mode — switch to Live for real AI output)');
  } else {
    const key = document.getElementById('apiKeyInput').value.trim();
    if (!key) {
      showNotif('⚠️ Enter your Claude API key to use Live mode');
      btn.disabled=false; txt.style.display='block'; spin.style.display='none';
      platforms.forEach(p => { document.getElementById(`out-${p}`).textContent='Add API key above.'; document.getElementById(`card-${p}`).classList.remove('loading'); });
      return;
    }
    await liveGenerate(key, content);
    showNotif('✅ Generated with Claude AI!');
  }

  btn.disabled=false; txt.style.display='block'; spin.style.display='none';
}

async function liveGenerate(key, content) {
  const platforms = [
    { id:'twitter', prompt:'Twitter/X thread — numbered tweets with hooks, max 280 chars each, engaging and punchy' },
    { id:'linkedin', prompt:'LinkedIn post — professional storytelling tone, 150-250 words, ends with a question' },
    { id:'instagram', prompt:'Instagram caption — warm, use emojis naturally, 80-120 words, 5-8 relevant hashtags at end' },
    { id:'tiktok', prompt:'TikTok hook/script — ultra short, pattern interrupt opener, 50-70 words max, very punchy' },
    { id:'newsletter', prompt:'Email newsletter intro — personal, warm, first-name greeting, 80-100 words, creates curiosity for the full piece' },
  ];
  const sys = 'You are a world-class social media strategist. Rewrite the given content perfectly for the specified platform. Return ONLY the final post text, nothing else.';
  for (const p of platforms) {
    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method:'POST',
        headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
        body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:700,system:sys,messages:[{role:'user',content:`Content:\n\n${content}\n\nRewrite as: ${p.prompt}`}]})
      });
      if (!res.ok) throw new Error((await res.json()).error?.message || 'API error');
      const d = await res.json();
      document.getElementById(`out-${p.id}`).textContent = d.content[0].text;
    } catch(e) {
      document.getElementById(`out-${p.id}`).textContent = `Error: ${e.message}`;
    }
    document.getElementById(`card-${p.id}`).classList.remove('loading');
  }
}

// ─── CURRENCY ───
function setCur(c) {
  cur = c;
  document.getElementById('usdBtn').classList.toggle('on', c==='usd');
  document.getElementById('eurBtn').classList.toggle('on', c==='eur');
  document.querySelectorAll('.csym').forEach(el => el.textContent = c==='usd'?'$':'€');
  document.querySelectorAll('.cval').forEach(el => el.textContent = el.dataset[c]);
}

// ─── COPY ───
function doCopy(platform, btn) {
  const txt = document.getElementById(`out-${platform}`).textContent;
  if (txt.startsWith('Hit ') || txt === 'Generating…') return;
  navigator.clipboard.writeText(txt).then(() => {
    btn.textContent = 'Copied!'; btn.classList.add('ok');
    setTimeout(() => { btn.textContent='Copy'; btn.classList.remove('ok'); }, 2000);
  });
}

// ─── NOTIF ───
function showNotif(msg) {
  const el = document.getElementById('notif');
  el.textContent = msg; el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 3500);
}

// ─── SCROLL REVEAL ───
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
}, { threshold:0.12 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ─── INIT ───
document.getElementById('contentInput').value = DEMO_CONTENT;
document.getElementById('apiSection').style.display = 'none';
// default EUR
let cur = 'eur';
document.querySelectorAll('.csym').forEach(el => el.textContent = '€');
document.querySelectorAll('.cval').forEach(el => el.textContent = el.dataset.eur);
</script>
</body>
</html>
