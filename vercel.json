<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>onepost – One post. Every platform.</title>
<style>
:root {
  --bg: #06060a;
  --bg2: #0c0c12;
  --surface: rgba(255,255,255,0.04);
  --surface-hover: rgba(255,255,255,0.07);
  --border: rgba(255,255,255,0.08);
  --border-bright: rgba(255,255,255,0.15);
  --accent: #8b5cf6;
  --accent2: #a78bfa;
  --accent3: #c4b5fd;
  --glow: rgba(139,92,246,0.3);
  --glow-soft: rgba(139,92,246,0.12);
  --text: #f8f8ff;
  --text2: rgba(248,248,255,0.6);
  --text3: rgba(248,248,255,0.35);
  --green: #34d399;
  --pink: #f472b6;
  --orange: #fb923c;
  --blue: #60a5fa;
  --radius: 16px;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ─── NOISE OVERLAY ─── */
body::before {
  content:''; position:fixed; inset:0; z-index:0; pointer-events:none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  opacity: 0.4;
}

/* ─── ORBS ─── */
.orb {
  position:fixed; border-radius:50%; filter:blur(120px);
  pointer-events:none; z-index:0;
}
.orb-1 { width:600px; height:600px; background:rgba(139,92,246,0.08); top:-200px; left:-100px; }
.orb-2 { width:500px; height:500px; background:rgba(96,165,250,0.05); bottom:0; right:-150px; }
.orb-3 { width:400px; height:400px; background:rgba(244,114,182,0.04); top:50%; left:50%; transform:translate(-50%,-50%); }

/* ─── NAV ─── */
nav {
  position:fixed; top:0; left:0; right:0; z-index:100;
  padding:0 40px;
  height:64px;
  display:flex; align-items:center; justify-content:space-between;
  background:rgba(6,6,10,0.7);
  backdrop-filter:blur(20px) saturate(180%);
  border-bottom:1px solid var(--border);
  transition: background .3s;
}
.logo {
  font-size:20px; font-weight:800; letter-spacing:-0.5px;
  background:linear-gradient(135deg, #fff 30%, var(--accent3));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.nav-center {
  display:flex; gap:4px;
}
.nav-center a {
  color:var(--text2); text-decoration:none; font-size:14px; font-weight:500;
  padding:7px 14px; border-radius:8px; transition:all .2s;
}
.nav-center a:hover { color:var(--text); background:var(--surface); }
.btn-nav {
  background:var(--accent); color:#fff; border:none; cursor:pointer;
  padding:8px 20px; border-radius:10px; font-size:14px; font-weight:600;
  transition:all .2s; letter-spacing:0.2px;
  box-shadow:0 0 20px rgba(139,92,246,0.3);
}
.btn-nav:hover { background:var(--accent2); transform:translateY(-1px); box-shadow:0 0 30px rgba(139,92,246,0.5); }

/* ─── SECTIONS ─── */
section { position:relative; z-index:1; }

/* ─── HERO ─── */
#hero {
  min-height:100vh;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  text-align:center;
  padding:120px 24px 80px;
}
.hero-eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(139,92,246,0.1); border:1px solid rgba(139,92,246,0.25);
  border-radius:100px; padding:6px 16px;
  font-size:12px; font-weight:600; color:var(--accent3); letter-spacing:0.5px;
  text-transform:uppercase;
  margin-bottom:32px;
}
.pulse { width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 2s infinite; }
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.85)}}

h1.hero-title {
  font-size:clamp(52px,8vw,96px);
  font-weight:900;
  line-height:1.0;
  letter-spacing:-3px;
  max-width:900px;
  margin-bottom:24px;
}
.grad-text {
  background:linear-gradient(135deg, #fff 0%, var(--accent3) 50%, var(--pink) 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text;
}
.hero-sub {
  font-size:18px; color:var(--text2); max-width:480px; line-height:1.7;
  margin-bottom:44px;
}
.hero-cta-row {
  display:flex; gap:12px; flex-wrap:wrap; justify-content:center; margin-bottom:60px;
}
.btn-primary {
  background:linear-gradient(135deg,var(--accent),#7c3aed);
  color:#fff; border:none; cursor:pointer;
  padding:14px 28px; border-radius:12px; font-size:15px; font-weight:700;
  transition:all .25s; box-shadow:0 0 40px rgba(139,92,246,0.35);
  letter-spacing:0.2px;
}
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 0 60px rgba(139,92,246,0.5); }
.btn-ghost {
  background:var(--surface); color:var(--text); border:1px solid var(--border-bright);
  cursor:pointer; padding:14px 28px; border-radius:12px; font-size:15px; font-weight:600;
  transition:all .25s; backdrop-filter:blur(8px);
}
.btn-ghost:hover { background:var(--surface-hover); border-color:rgba(255,255,255,0.25); }

/* Platform pills */
.platform-row {
  display:flex; gap:8px; flex-wrap:wrap; justify-content:center;
}
.platform-pill {
  display:flex; align-items:center; gap:7px;
  background:var(--surface); border:1px solid var(--border);
  border-radius:100px; padding:8px 16px;
  font-size:13px; font-weight:500; color:var(--text2);
  backdrop-filter:blur(8px);
  transition:all .2s;
}
.platform-pill:hover { border-color:var(--border-bright); color:var(--text); }

/* ─── STATS BAR ─── */
#stats {
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  background:rgba(255,255,255,0.02);
  padding:32px 0;
}
.stats-inner {
  max-width:900px; margin:0 auto; padding:0 24px;
  display:grid; grid-template-columns:repeat(4,1fr); gap:24px;
}
@media(max-width:600px){.stats-inner{grid-template-columns:repeat(2,1fr);}}
.stat-item { text-align:center; }
.stat-num {
  font-size:32px; font-weight:900; letter-spacing:-1px;
  background:linear-gradient(135deg, #fff, var(--accent3));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.stat-label { font-size:13px; color:var(--text3); margin-top:4px; }

/* ─── HOW IT WORKS ─── */
#how {
  padding:120px 24px;
}
.section-inner { max-width:1100px; margin:0 auto; }
.section-tag {
  text-align:center; font-size:12px; font-weight:700; color:var(--accent2);
  letter-spacing:2px; text-transform:uppercase; margin-bottom:16px;
}
.section-title {
  text-align:center; font-size:clamp(32px,4vw,52px);
  font-weight:800; letter-spacing:-1.5px; margin-bottom:16px; line-height:1.1;
}
.section-sub {
  text-align:center; color:var(--text2); font-size:17px;
  max-width:440px; margin:0 auto 64px; line-height:1.65;
}

.steps-grid {
  display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
  background:var(--border);
  border:1px solid var(--border); border-radius:20px; overflow:hidden;
}
@media(max-width:700px){.steps-grid{grid-template-columns:1fr;}}
.step {
  background:var(--bg2); padding:40px 36px;
  position:relative; transition:background .3s;
}
.step:hover { background:rgba(255,255,255,0.03); }
.step-icon {
  width:48px; height:48px; border-radius:12px;
  background:rgba(139,92,246,0.12); border:1px solid rgba(139,92,246,0.2);
  display:flex; align-items:center; justify-content:center;
  font-size:22px; margin-bottom:24px;
}
.step h3 { font-size:18px; font-weight:700; margin-bottom:10px; letter-spacing:-0.3px; }
.step p { color:var(--text2); font-size:15px; line-height:1.65; }
.step-num {
  position:absolute; top:24px; right:24px;
  font-size:11px; font-weight:700; color:var(--text3); letter-spacing:1px;
}

/* ─── APP DEMO ─── */
#demo {
  padding:40px 24px 120px;
}
.demo-wrapper {
  max-width:1200px; margin:0 auto;
  background:var(--surface); border:1px solid var(--border);
  border-radius:24px; overflow:hidden;
  backdrop-filter:blur(20px);
}
.demo-toolbar {
  background:rgba(255,255,255,0.03); border-bottom:1px solid var(--border);
  padding:14px 20px; display:flex; align-items:center; gap:8px;
}
.dot { width:12px;height:12px;border-radius:50%; }
.dot-r{background:#ff5f57;} .dot-y{background:#ffbd2e;} .dot-g{background:#28ca41;}
.demo-url {
  flex:1; background:rgba(255,255,255,0.05); border:1px solid var(--border);
  border-radius:6px; padding:5px 12px; font-size:12px; color:var(--text3);
  margin:0 16px;
}
.demo-body {
  display:grid; grid-template-columns:1fr 1fr; min-height:520px;
}
@media(max-width:800px){.demo-body{grid-template-columns:1fr;}}

.demo-input-col {
  padding:32px; border-right:1px solid var(--border);
  display:flex; flex-direction:column; gap:16px;
}
.demo-label {
  font-size:11px; font-weight:700; color:var(--text3);
  text-transform:uppercase; letter-spacing:1.5px;
}
textarea.demo-ta {
  flex:1; min-height:200px;
  background:rgba(255,255,255,0.03); border:1px solid var(--border);
  border-radius:12px; padding:16px; color:var(--text);
  font-size:14px; font-family:inherit; line-height:1.65;
  resize:none; outline:none; transition:border-color .2s;
}
textarea.demo-ta:focus { border-color:rgba(139,92,246,0.5); }
textarea.demo-ta::placeholder { color:var(--text3); }

.mode-row { display:flex; gap:8px; }
.mode-pill {
  flex:1; padding:9px; border-radius:9px; font-size:13px; font-weight:600;
  border:1px solid var(--border); background:transparent; color:var(--text2);
  cursor:pointer; transition:all .2s; text-align:center;
}
.mode-pill.on { background:rgba(139,92,246,0.15); border-color:rgba(139,92,246,0.4); color:var(--accent3); }

.api-field {
  background:rgba(255,255,255,0.03); border:1px solid var(--border);
  border-radius:10px; padding:11px 14px; color:var(--text);
  font-size:13px; font-family:inherit; outline:none; width:100%;
  transition:border-color .2s;
}
.api-field:focus { border-color:rgba(139,92,246,0.5); }
.api-field::placeholder { color:var(--text3); }
.api-hint { font-size:11px; color:var(--text3); }
.api-hint a { color:var(--accent2); text-decoration:none; }

.btn-gen {
  background:linear-gradient(135deg,var(--accent),#7c3aed);
  color:#fff; border:none; cursor:pointer;
  padding:14px; border-radius:12px; font-size:15px; font-weight:700;
  transition:all .25s; box-shadow:0 0 30px rgba(139,92,246,0.3);
  display:flex; align-items:center; justify-content:center; gap:8px;
}
.btn-gen:hover:not(:disabled) { transform:translateY(-1px); box-shadow:0 0 50px rgba(139,92,246,0.5); }
.btn-gen:disabled { opacity:0.5; cursor:not-allowed; }
.spin { width:16px;height:16px;border:2px solid rgba(255,255,255,0.2);border-top-color:#fff;border-radius:50%;animation:sp .7s linear infinite;display:none; }
@keyframes sp{to{transform:rotate(360deg)}}

.demo-output-col {
  padding:24px; display:flex; flex-direction:column; gap:12px;
  overflow-y:auto; max-height:520px;
}
.demo-output-col::-webkit-scrollbar{width:4px;}
.demo-output-col::-webkit-scrollbar-track{background:transparent;}
.demo-output-col::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

.out-card {
  background:rgba(255,255,255,0.03); border:1px solid var(--border);
  border-radius:14px; padding:16px; transition:all .3s;
}
.out-card.loading { opacity:0.4; }
.out-header {
  display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;
}
.out-platform {
  display:flex; align-items:center; gap:8px; font-size:13px; font-weight:700;
}
.out-actions { display:flex; gap:6px; align-items:center; }
.demo-tag {
  font-size:10px; font-weight:700; color:var(--orange); letter-spacing:1px;
  background:rgba(251,146,60,0.1); border:1px solid rgba(251,146,60,0.2);
  border-radius:4px; padding:2px 7px;
}
.btn-copy {
  background:rgba(255,255,255,0.05); border:1px solid var(--border);
  color:var(--text2); cursor:pointer; padding:4px 10px; border-radius:6px;
  font-size:11px; font-weight:600; transition:all .2s;
}
.btn-copy:hover { border-color:var(--border-bright); color:var(--text); }
.btn-copy.ok { background:rgba(52,211,153,0.1); border-color:rgba(52,211,153,0.3); color:var(--green); }

.out-text {
  color:var(--text2); font-size:13px; line-height:1.65;
  white-space:pre-wrap; word-break:break-word;
  max-height:140px; overflow-y:auto;
}
.out-text::-webkit-scrollbar{width:3px;}
.out-text::-webkit-scrollbar-track{background:transparent;}
.out-text::-webkit-scrollbar-thumb{background:var(--border);}

/* ─── COMPARE ─── */
#compare { padding:120px 24px; }
.compare-wrap { overflow-x:auto; border-radius:20px; border:1px solid var(--border); }
table.cmp {
  width:100%; border-collapse:collapse; font-size:14px; min-width:600px;
}
.cmp thead th {
  padding:16px 20px; text-align:center;
  font-size:12px; font-weight:700; color:var(--text3);
  text-transform:uppercase; letter-spacing:1px;
  background:rgba(255,255,255,0.02);
  border-bottom:1px solid var(--border);
}
.cmp thead th:first-child { text-align:left; }
.cmp thead th.us-col {
  background:rgba(139,92,246,0.08);
  color:var(--accent3); border-left:1px solid rgba(139,92,246,0.2); border-right:1px solid rgba(139,92,246,0.2);
}
.cmp tbody td {
  padding:14px 20px; text-align:center;
  border-bottom:1px solid rgba(255,255,255,0.04); color:var(--text2);
}
.cmp tbody tr:last-child td { border-bottom:none; }
.cmp tbody td:first-child { text-align:left; font-weight:600; color:var(--text); }
.cmp tbody td.us-col {
  background:rgba(139,92,246,0.05);
  font-weight:700; color:var(--text);
  border-left:1px solid rgba(139,92,246,0.15); border-right:1px solid rgba(139,92,246,0.15);
}
.cmp tbody tr:last-child td.us-col { border-radius:0 0 0 0; }
.ck { color:var(--green); font-size:15px; }
.xx { color:rgba(255,255,255,0.2); font-size:15px; }
.price-highlight { color:var(--green); font-size:16px; font-weight:900; }

/* ─── PRICING ─── */
#pricing { padding:120px 24px; }
.cur-toggle {
  display:flex; justify-content:center; margin-bottom:40px;
}
.cur-inner {
  display:flex; background:var(--surface); border:1px solid var(--border);
  border-radius:10px; padding:3px; gap:2px;
}
.cur-btn {
  padding:7px 18px; border:none; background:transparent; color:var(--text2);
  cursor:pointer; border-radius:8px; font-size:13px; font-weight:700; transition:all .2s;
}
.cur-btn.on { background:var(--accent); color:#fff; }

.trial-banner {
  max-width:640px; margin:0 auto 48px;
  background:rgba(52,211,153,0.06); border:1px solid rgba(52,211,153,0.2);
  border-radius:14px; padding:16px 24px;
  display:flex; align-items:center; justify-content:center; gap:12px;
  font-size:14px; font-weight:600; color:var(--green);
}

.plans {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:16px; max-width:920px; margin:0 auto;
}
@media(max-width:700px){.plans{grid-template-columns:1fr;}}

.plan {
  background:var(--surface); border:1px solid var(--border);
  border-radius:20px; padding:32px; position:relative;
  transition:border-color .3s, transform .3s;
}
.plan:hover { border-color:var(--border-bright); transform:translateY(-2px); }
.plan.highlight {
  background:rgba(139,92,246,0.06);
  border-color:rgba(139,92,246,0.4);
  box-shadow:0 0 60px rgba(139,92,246,0.1);
}
.plan-badge {
  position:absolute; top:-12px; left:50%; transform:translateX(-50%);
  background:var(--accent); color:#fff; font-size:10px; font-weight:800;
  padding:4px 14px; border-radius:100px; letter-spacing:1.5px; white-space:nowrap;
}
.plan-name {
  font-size:12px; font-weight:700; color:var(--text3);
  text-transform:uppercase; letter-spacing:2px; margin-bottom:20px;
}
.plan-price {
  font-size:52px; font-weight:900; letter-spacing:-2px; line-height:1;
  margin-bottom:4px;
}
.plan-price sup { font-size:20px; font-weight:600; vertical-align:top; margin-top:10px; display:inline-block; color:var(--text2); }
.plan-period { font-size:13px; color:var(--text3); margin-bottom:6px; }
.plan-save {
  display:inline-block; font-size:11px; font-weight:700; color:var(--green);
  background:rgba(52,211,153,0.1); border:1px solid rgba(52,211,153,0.2);
  border-radius:6px; padding:2px 9px; margin-bottom:24px;
}
.plan-divider { height:1px; background:var(--border); margin-bottom:20px; }
.plan-features { list-style:none; display:flex; flex-direction:column; gap:10px; margin-bottom:28px; }
.plan-features li {
  display:flex; align-items:flex-start; gap:9px;
  font-size:14px; color:var(--text2); line-height:1.4;
}
.plan-features li .fi { color:var(--green); font-size:13px; flex-shrink:0; margin-top:1px; }
.plan-features li.off { color:var(--text3); }
.plan-features li.off .fi { color:var(--text3); }
.btn-plan {
  width:100%; padding:13px; border-radius:12px; font-size:14px; font-weight:700;
  cursor:pointer; border:none; transition:all .25s; letter-spacing:0.2px;
}
.btn-plan.ghost { background:transparent; border:1px solid var(--border-bright); color:var(--text); }
.btn-plan.ghost:hover { background:var(--surface-hover); }
.btn-plan.fill { background:linear-gradient(135deg,var(--accent),#7c3aed); color:#fff; box-shadow:0 0 30px rgba(139,92,246,0.3); }
.btn-plan.fill:hover { transform:translateY(-1px); box-shadow:0 0 50px rgba(139,92,246,0.5); }
.plan-footnote { text-align:center; font-size:12px; color:var(--text3); margin-top:20px; }

/* ─── CTA BAND ─── */
#cta {
  padding:100px 24px;
  text-align:center;
}
.cta-box {
  max-width:700px; margin:0 auto;
  background:linear-gradient(135deg, rgba(139,92,246,0.1), rgba(96,165,250,0.06));
  border:1px solid rgba(139,92,246,0.25);
  border-radius:28px; padding:64px 48px;
  position:relative; overflow:hidden;
}
.cta-box::before {
  content:''; position:absolute; top:-1px; left:20%; right:20%; height:1px;
  background:linear-gradient(90deg, transparent, var(--accent), transparent);
}
.cta-box h2 { font-size:clamp(28px,4vw,44px); font-weight:900; letter-spacing:-1.5px; margin-bottom:16px; }
.cta-box p { font-size:16px; color:var(--text2); margin-bottom:36px; line-height:1.6; }

/* ─── FOOTER ─── */
footer {
  border-top:1px solid var(--border);
  padding:32px 40px;
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:16px;
}
.footer-logo { font-size:16px; font-weight:800; color:var(--text2); }
.footer-links { display:flex; gap:24px; }
.footer-links a { font-size:13px; color:var(--text3); text-decoration:none; transition:color .2s; }
.footer-links a:hover { color:var(--text2); }
.footer-copy { font-size:13px; color:var(--text3); }

/* ─── SCROLL ANIMATIONS ─── */
.reveal {
  opacity:0; transform:translateY(28px);
  transition:opacity .7s ease, transform .7s ease;
}
.reveal.visible { opacity:1; transform:translateY(0); }
.reveal-delay-1 { transition-delay:.1s; }
.reveal-delay-2 { transition-delay:.2s; }
.reveal-delay-3 { transition-delay:.3s; }

/* ─── NOTIFICATION ─── */
.notif {
  position:fixed; bottom:24px; right:24px; z-index:999;
  background:rgba(20,20,28,0.95); border:1px solid var(--border-bright);
  border-radius:14px; padding:14px 20px; font-size:14px; font-weight:500;
  display:flex; align-items:center; gap:10px;
  transform:translateY(80px); opacity:0; transition:all .35s cubic-bezier(.34,1.56,.64,1);
  backdrop-filter:blur(16px); max-width:300px;
}
.notif.show { transform:translateY(0); opacity:1; }
</style>
</head>
<body>

<div class="orb orb-1"></div>
